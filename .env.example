# Copy to .env — never commit .env to git

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
EMBED_MODEL=text-embedding-3-small

# Vector store: "faiss" (local) | "chroma" (persistent)
VECTOR_STORE=faiss
POLICY_DIR=data/policies
CHUNK_SIZE=800
CHUNK_OVERLAP=100
CHROMA_DIR=/tmp/dg_rag_chroma

# Database: "sqlite" (dev) | "postgres" (prod)
DB_BACKEND=sqlite
SQLITE_PATH=data/policy.db
PG_HOST=localhost
PG_PORT=5432
PG_DB=policy_rag
PG_USER=postgres
PG_PASSWORD=

ENCRYPTION_KEY=
ENCRYPTION_KEY_PATH=/tmp/dg_rag.key

CACHE_DIR=/tmp/dg_rag_cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_ENTRIES=1000

# HITL: "auto" | "cli" | "queue"
HITL_MODE=auto
HITL_TIMEOUT=120
HITL_AUTO_PASS=true
HITL_QUEUE_DIR=/tmp/hitl_queue

RETRIEVAL_TOP_K=6
TOKEN_THRESHOLD=3000
TRACE_DIR=/tmp/dg_rag_traces
