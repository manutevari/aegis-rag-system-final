# ===== Provider credentials =====
# Fill these in your deployment environment. Leave blank for safe local fallback.
OPENAI_API_KEY=
COHERE_API_KEY=
PINECONE_API_KEY=

# ===== OpenAI generation =====
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_OUTPUT_TOKENS=1024

# ===== OpenAI embeddings =====
RAG_EMBEDDINGS_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
LOCAL_HASH_EMBED_DIM=384
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALLOW_HF_DOWNLOADS=false

# ===== Pinecone vector database =====
VECTOR_BACKEND=pinecone
PINECONE_INDEX_NAME=aegis-policies
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=cosine
PINECONE_CREATE_INDEX=false
PINECONE_BATCH_SIZE=100

# ===== Cohere reranking =====
RERANK_PROVIDER=cohere
COHERE_RERANK_MODEL=rerank-v3.5
RERANK_MODEL=rerank-v3.5
RERANK_TOP_K=5
RETRIEVAL_BROAD_K=25

# ===== AEGIS ingestion =====
SEMANTIC_CHUNK_TOKENS=450
CHUNK_OVERLAP_RATIO=0.12
TABLE_ROW_CHUNK_LIMIT=18

# ===== Local fallback runtime =====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_HEALTH_TIMEOUT=0.5

# ===== Local fallback DB =====
CHROMA_DIR=db
CHROMA_COLLECTION=aegis_policies
DB_PATH=app/db/policy.db

# ===== HITL mode =====
HITL_MODE=auto
