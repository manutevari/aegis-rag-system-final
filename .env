# ===== Local runtime =====
# FastAPI works without Ollama by default. Set LLM_PROVIDER=ollama only when
# an Ollama server is running and reachable at OLLAMA_BASE_URL.
LLM_PROVIDER=extractive
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ===== Local embeddings =====
RAG_EMBEDDINGS_PROVIDER=local
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALLOW_HF_DOWNLOADS=false
LOCAL_HASH_EMBED_DIM=384

# ===== App / DB =====
CHROMA_DIR=db
CHROMA_COLLECTION=aegis_policies
DB_PATH=app/db/policy.db

# ===== HITL mode =====
HITL_MODE=auto
