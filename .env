# ===== Provider credentials =====
# Fill these in your deployment environment only when enabling optional remote services.
# Runtime LLM calls are local-only by default.
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
PINECONE_API_KEY=

# ===== Local LLM orchestration =====
LLM_PROVIDER=local_auto
LOCAL_LLM_ORDER=ollama,llama_cpp,mistral_local
LOCAL_LLM_TEMPERATURE=0.0
LOCAL_LLM_HEALTH_TIMEOUT=0.5
LOCAL_ORCHESTRATION_MODEL=llama3.1
LOCAL_GENERATION_MODEL=mistral
LOCAL_SUMMARY_MODEL=mistral

# Ollama is tried first when reachable, then llama.cpp, then Mistral Local.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

LLAMA_CPP_BASE_URL=http://localhost:8080/v1
LLAMA_CPP_MODEL=local-model

MISTRAL_LOCAL_BASE_URL=http://localhost:8000/v1
MISTRAL_LOCAL_MODEL=mistral

# ===== Local embeddings and vector database =====
RAG_EMBEDDINGS_PROVIDER=hash
LOCAL_HASH_EMBED_DIM=384
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALLOW_HF_DOWNLOADS=false

VECTOR_BACKEND=chroma
CHROMA_DIR=db
CHROMA_COLLECTION=aegis_policies
DB_PATH=app/db/policy.db

# Optional remote vector database settings, unused unless VECTOR_BACKEND=pinecone.
PINECONE_INDEX_NAME=aegis-policies
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_METRIC=cosine
PINECONE_CREATE_INDEX=false
PINECONE_BATCH_SIZE=100

# ===== Local reranking =====
RERANK_PROVIDER=local
RERANK_MODEL=lexical
RERANK_TOP_K=5
RETRIEVAL_BROAD_K=25

# ===== AEGIS ingestion =====
SEMANTIC_CHUNK_TOKENS=450
CHUNK_OVERLAP_RATIO=0.12
TABLE_ROW_CHUNK_LIMIT=18

# ===== HITL mode =====
HITL_MODE=auto
