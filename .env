# ===== OpenAI (primary) =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# ===== OpenRouter (fallback) =====
# You can use EITHER name; your patched models.py accepts both
OPENROUTER_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Optional fallback model (OpenRouter)
FALLBACK_MODEL=mistralai/mixtral-8x7b

# ===== Model tuning =====
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ===== Embeddings =====
EMBED_MODEL=text-embedding-3-small

# ===== App / DB =====
DB_PATH=app/db/policy.db

# ===== HITL mode =====
HITL_MODE=auto
