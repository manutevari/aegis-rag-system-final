# ===== Local runtime =====
# FastAPI works without Ollama by default. Set LLM_PROVIDER=ollama only when
# an Ollama server is running and reachable at OLLAMA_BASE_URL.
LLM_PROVIDER=extractive
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ===== Local embeddings =====
# Hash embeddings avoid torch/torchvision/transformers runtime imports and work
# in Streamlit/FastAPI without downloads. Set RAG_EMBEDDINGS_PROVIDER=local only
# when a dense sentence-transformer model is installed and working.
RAG_EMBEDDINGS_PROVIDER=hash
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALLOW_HF_DOWNLOADS=false
LOCAL_HASH_EMBED_DIM=384

# ===== AEGIS ingestion =====
SEMANTIC_CHUNK_TOKENS=450
CHUNK_OVERLAP_RATIO=0.12
TABLE_ROW_CHUNK_LIMIT=18

# ===== AEGIS retrieval =====
RETRIEVAL_BROAD_K=25
RERANK_TOP_K=5
RERANK_PROVIDER=lexical
RERANK_MODEL=BAAI/bge-reranker-base

# ===== App / DB =====
CHROMA_DIR=db
CHROMA_COLLECTION=aegis_policies
DB_PATH=app/db/policy.db

# ===== HITL mode =====
HITL_MODE=auto
